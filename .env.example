# Airflow Configuration
AIRFLOW_HOME=/home/airflow/airflow
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=CHANGE_ME
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__MAX_ACTIVE_TASKS_PER_DAG=16
AIRFLOW__CORE__PARALLELISM=32

# Airflow admin user — change before first run
AIRFLOW_ADMIN_USER=CHANGE_ME
AIRFLOW_ADMIN_PASSWORD=CHANGE_ME
AIRFLOW_ADMIN_EMAIL=CHANGE_ME@example.com

# PostgreSQL — change before first run
POSTGRES_USER=CHANGE_ME
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=airflow

# Grafana — change before first run
GRAFANA_ADMIN_USER=CHANGE_ME
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# BigQuery (optional, for Phase 3)
# GCP_PROJECT_ID=your-project-id
# GCP_SERVICE_ACCOUNT_FILE=/home/airflow/airflow/credentials/service_account.json

# dbt (optional, for Phase 3)
# DBT_PROFILES_DIR=/home/airflow/.dbt

# Data paths
DATA_VOLUME=/tmp/airflow_data
LOGS_VOLUME=/tmp/airflow_logs
