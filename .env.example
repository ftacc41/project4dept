# Airflow Configuration
AIRFLOW_HOME=/home/airflow/airflow
AIRFLOW_FERNET_KEY=REDACTED_FERNET_KEY
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__MAX_ACTIVE_TASKS_PER_DAG=16
AIRFLOW__CORE__PARALLELISM=32

# PostgreSQL
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# BigQuery (optional, for Phase 3)
# GCP_PROJECT_ID=your-project-id
# GCP_SERVICE_ACCOUNT_FILE=/home/airflow/airflow/credentials/service_account.json

# dbt (optional, for Phase 3)
# DBT_PROFILES_DIR=/home/airflow/.dbt

# Data paths
DATA_VOLUME=/tmp/airflow_data
LOGS_VOLUME=/tmp/airflow_logs
